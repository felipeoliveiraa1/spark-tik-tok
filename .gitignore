# Spark — gitignore

# ----- Dependencies / build output -----
**/node_modules/
**/dist/
**/.next/
**/out/
**/.turbo/
**/.vercel/
**/coverage/
**/build/

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- Env files (commit only the example) -----
.env
.env.*
!.env.production.example

# ----- OS / editor -----
.DS_Store
*.pem
*.log
.idea/
.vscode/

# ----- Scraper runtime data (cookies, sessions) -----
backend/scraper/data/*
!backend/scraper/data/.gitkeep
backend/scraper/vyral-cookies.json
backend/scraper/vyral-session.json

# ----- Local artifacts (HAR dumps, design refs, audio transcripts) -----
*.har
_design-reference/
*.txt
!**/README*.txt
!docs/**/*.txt
