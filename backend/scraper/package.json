{
  "name": "@spark/scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Vyral.com.br scraping worker — runs on Contabo VPS, exposes HMAC-protected HTTP endpoints, persists session.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx --env-file=.env watch src/server.ts",
    "start": "node --env-file=.env dist/server.js",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.34.0",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "playwright": "^1.49.1",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
