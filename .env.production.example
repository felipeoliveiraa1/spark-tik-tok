# =============================================================================
# Spark — VPS production env (loaded by docker-compose --env-file)
# Copy to .env.production on the VPS and fill the secrets.
# =============================================================================

# --- Host port for the scraper (change if 4001 is taken on this VPS) ---------
SCRAPER_PORT=4001

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=spark
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=spark

# --- Scraper ↔ Next.js shared secret (HMAC) ----------------------------------
# Generate with: openssl rand -hex 32
# IMPORTANT: must match the value set in Vercel's project env.
SCRAPER_HMAC_SECRET=change-me-too

# --- Vyral (optional today — the cookie file is what authenticates) ----------
# Used when we add an automated re-login path. Leave blank to skip.
VYRAL_EMAIL=
VYRAL_PASSWORD=
