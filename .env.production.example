# =============================================================================
# Spark — VPS production env (loaded by docker-compose --env-file)
# Copy to .env.production on the VPS and fill the secrets.
# =============================================================================

# --- Host port for the scraper (change if 4001 is taken on this VPS) ---------
SCRAPER_PORT=4001

# --- Supabase Postgres connection string -------------------------------------
# Get from Supabase Dashboard → Settings → Database → Connection string (URI).
# For the worker, "Direct" mode is fine. Upgrade to the pooler URL if you ever
# scale to many concurrent jobs.
DATABASE_URL=postgresql://postgres:CHANGE_ME@db.PROJECT.supabase.co:5432/postgres

# --- Scraper ↔ Next.js shared secret (HMAC) ----------------------------------
# Generate with: openssl rand -hex 32
# IMPORTANT: must match SCRAPER_HMAC_SECRET in Vercel's project env.
SCRAPER_HMAC_SECRET=change-me-too

# --- Vyral (optional today — the cookie file authenticates the requests) ----
VYRAL_EMAIL=
VYRAL_PASSWORD=
